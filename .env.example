# LlevaLleva -- environment variables (example)
# Copy to .env.local for local development. Set via Netlify UI for production.

# ---- Site origin -----------------------------------------------------------
# Used for canonical URLs, sitemap, OpenGraph, and JSON-LD.
NEXT_PUBLIC_SITE_URL=https://lleva-lleva.com

# ---- Supabase --------------------------------------------------------------
# Auth + database. The publishable (anon) key is safe in client bundles;
# service-role secrets must NEVER be committed and stay server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Gemini (price-check tool) --------------------------------------------
# REQUIRED for the /cuanto-vale price-check feature. Used by both:
#   - app/api/price-check/route.ts (Next.js route handler -- canonical)
#   - netlify/functions/price-check.mjs (legacy Netlify Function, kept for
#     back-compat -- to be removed in a follow-up pass).
# Without this var the price tool returns HTTP 500 and PriceChecker.tsx
# shows the opaque "Error de conexion" message to users.
# Obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Override the default model. Optional; defaults to gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# ---- Google Analytics 4 ----------------------------------------------------
# Measurement id (G-XXXXXXXXXX). Loaded client-side by the Consent Mode v2
# scaffold. Leave blank in preview deploys.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ---- Google AdSense slot ids ----------------------------------------------
# Per-placement slot ids issued in the AdSense console. The publisher id is
# expected to be the canonical Maia ca-pub (see scripts/ads.js); slot ids
# differ per surface and are safe to commit.
NEXT_PUBLIC_ADSENSE_SLOT_CATEGORY=
NEXT_PUBLIC_ADSENSE_SLOT_HOMEPAGE_BANNER=
NEXT_PUBLIC_ADSENSE_SLOT_HOMEPAGE_FEED=
NEXT_PUBLIC_ADSENSE_SLOT_LISTING_CONTENT=
NEXT_PUBLIC_ADSENSE_SLOT_LISTING_SIDEBAR=

# ---- Twilio WhatsApp (lead alerts) ----------------------------------------
# Used by Netlify Functions only; never expose to the client. The shared
# Maia bot number is wa.me/19034598763 -- this is the messaging-only API
# credential pair, not the receptionist line.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
